# UNWI — environment variables
#
# Copy to .env.local for local dev; configure as Amplify env vars for deploy.
# The classifier Lambda has its own env vars (DB_SECRET_ARN, AURORA_HOST,
# S3_BUCKET, S3_PREFIX) set via CloudFormation; see infra/template.yaml.

# --- Aurora Serverless v2 (or local Docker Postgres for dev) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5433/unwi

# --- Cognito hosted-login ---
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXX
COGNITO_REGION=eu-west-1
COGNITO_DOMAIN=unwi-auth.auth.eu-west-1.amazoncognito.com
