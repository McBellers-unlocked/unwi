# --- Cognito hosted-login ---
COGNITO_USER_POOL_ID=eu-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXX
COGNITO_REGION=eu-west-1
COGNITO_DOMAIN=unwi-auth.auth.eu-west-1.amazoncognito.com

# --- Cron protection ---
# Both /api/cron/snapshot and /api/cron/snapshot-manual require header `x-cron-secret`.
CRON_SECRET=change-me-to-a-long-random-string

# --- Cost methodology ---
# Conservative mid-point between SHRM standard cost-per-hire (USD 4,700) and executive
# benchmark (USD 28,329). JIU figure to be finalised.
USD_PER_RECRUITMENT=20000
USD_TO_EUR_RATE=0.92

# --- YTD anchor (optional override; default is fiscal-year aligned 2025-08-01) ---
YTD_ANCHOR_DATE=2025-08-01
